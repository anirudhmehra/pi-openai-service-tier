{
  "name": "pi-openai-service-tier",
  "version": "0.1.2",
  "description": "Cost-correct OpenAI service tier / fast mode extension for pi",
  "type": "module",
  "license": "MIT",
  "author": "Anirudh Mehra",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "openai",
    "codex",
    "fast",
    "priority",
    "service-tier"
  ],
  "homepage": "https://github.com/anirudhmehra/pi-openai-service-tier#readme",
  "bugs": {
    "url": "https://github.com/anirudhmehra/pi-openai-service-tier/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anirudhmehra/pi-openai-service-tier.git"
  },
  "files": [
    "index.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "check": "npm run typecheck && npm test && npm run pack:dry-run",
    "pack:dry-run": "npm pack --dry-run",
    "test": "node --test --experimental-strip-types index.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": ">=0.72.1",
    "@mariozechner/pi-coding-agent": ">=0.72.1"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.72.1",
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.6.2"
}
